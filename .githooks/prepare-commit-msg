#!/bin/sh
set -e

# 1. 环境自适应
[ -d "/c/Portable Files" ] && export PATH="/c/Portable Files/PortableGit/bin:/c/Portable Files/PortableGit/usr/bin:$PATH"

COMMIT_MSG_FILE=$1
# 2. 获取并清洗消息：核心——脱掉 [skip ci] 再算长度
ORIGINAL_MSG=$(cat "$COMMIT_MSG_FILE" | xargs)
CLEAN_MSG=$(echo "$ORIGINAL_MSG" | sed 's/\[skip ci\]//g' | xargs)
CLEAN_LENGTH=$(echo -n "$CLEAN_MSG" | wc -m | tr -d ' ')

IS_TRIGGER=0
# 使用最稳的前缀匹配
case "$CLEAN_MSG" in
    up*|update*|Update*|Create*|Delete*|Rename*|"") IS_TRIGGER=1 ;;
esac

# 3. 判定逻辑：有效信息不足 10 字，或命中触发词
if [ "$CLEAN_LENGTH" -lt 10 ] || [ "$IS_TRIGGER" -eq 1 ]; then
    
    # 4. 统计物理变更
    DIFF_DATA=$(git diff --cached --name-status)
    [ -z "$DIFF_DATA" ] && exit 0

    SUBJECT=""
    BODY=""
    
    # 分类提取文件清单
    ADD_RAW=$(echo "$DIFF_DATA" | awk '$1~/^A/{print $2}')
    MOD_RAW=$(echo "$DIFF_DATA" | awk '$1~/^M/{print $2}')
    DEL_RAW=$(echo "$DIFF_DATA" | awk '$1~/^D/{print $2}')

    [ -n "$ADD_RAW" ] && SUBJECT="${SUBJECT}新增 $(echo "$ADD_RAW" | wc -l | tr -d ' ') 个文件，" && BODY="${BODY}[新增] $(echo "$ADD_RAW" | paste -sd ", " -)\n"
    [ -n "$MOD_RAW" ] && SUBJECT="${SUBJECT}修订 $(echo "$MOD_RAW" | wc -l | tr -d ' ') 个文件，" && BODY="${BODY}[修订] $(echo "$MOD_RAW" | paste -sd ", " -)\n"
    [ -n "$DEL_RAW" ] && SUBJECT="${SUBJECT}删除 $(echo "$DEL_RAW" | wc -l | tr -d ' ') 个文件，" && BODY="${BODY}[删除] $(echo "$DEL_RAW" | paste -sd ", " -)\n"

    # 5. 格式化组装
    if [ -n "$SUBJECT" ]; then
        SUBJECT=$(echo "$SUBJECT" | sed 's/，$//')
        # 找回被扣掉的 [skip ci] 标签
        SKIP_TAG=$(echo "$ORIGINAL_MSG" | grep -o "\[skip ci\]" || true)
        
        # 最终输出：标题 \n\n 正文路径 \n 标签
        printf "%s\n\n%b\n%s" "$SUBJECT" "$BODY" "$SKIP_TAG" > "$COMMIT_MSG_FILE"
    fi
fi