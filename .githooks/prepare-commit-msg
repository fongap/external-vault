#!/bin/sh
# =============================================================================================
# 脚本名称：prepare-commit-msg
#
# 【功能】
# Git 提交预处理钩子。根据输入特征，自动将无效或简短的提交信息替换为具体的文件变更列表。
# 替换格式示例：“新增 a.txt; 修订 b.py; 删除 c.md”。
#
# 【触发与放行规则】
# 1. 触发替换：输入字符数 <= 阈值（默认10），或匹配 GitHub 默认提交格式。
# 2. 放行保留：输入字符数 > 阈值，且非 GitHub 默认格式（判定为有效自定义备注）。
#
# 【部署说明】（适用于仓库统一管理，免复制）
# 1. 存放路径：项目根目录 `.githooks/prepare-commit-msg`（必须无后缀名）。
# 2. 生效指令：在终端执行 `git config core.hooksPath .githooks`。
# 3. 权限要求：在终端执行 `chmod +x .githooks/prepare-commit-msg`。
# =============================================================================================

set -e
set -u

# Windows: 添加Git路径；Linux/CI环境跳过
if [ -d "/c/Portable Files" ]; then
    export PATH="/c/Portable Files/PortableGit/bin:/c/Portable Files/PortableGit/usr/bin:$PATH"
fi

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=${2:-}

# 跳过合并/压缩等特殊操作
if [ "$COMMIT_SOURCE" = "merge" ] || [ "$COMMIT_SOURCE" = "squash" ]; then
    exit 0
fi

ORIGINAL_MSG=$(cat "$COMMIT_MSG_FILE" | xargs)
MSG_LENGTH=$(echo -n "$ORIGINAL_MSG" | wc -m | tr -d ' ')
THRESHOLD=10
IS_GITHUB_DEFAULT=0

# 检测GitHub默认提交格式
case "$ORIGINAL_MSG" in
    Update*|Create*|Delete*|Rename*|"update"|"")
        IS_GITHUB_DEFAULT=1
        ;;
esac

# 有效自定义备注直接保留
if [ "$MSG_LENGTH" -gt "$THRESHOLD" ] && [ "$IS_GITHUB_DEFAULT" -eq 0 ]; then
    exit 0
fi

# =========================================================
# 构建变更摘要：极简标题(首行) + 文件列表(正文)
# =========================================================

SUBJECT=""
BODY=""
HAS_CHANGE=0

# 新增文件处理 (A)
ADDED_RAW=$(git diff --cached --name-status | awk '$1 ~ /^A/ {print $2}')
if [ -n "$ADDED_RAW" ]; then
    COUNT=$(echo "$ADDED_RAW" | wc -l | tr -d ' ')
    FULL=$(echo "$ADDED_RAW" | paste -sd ", " -)
    
    SUBJECT="${SUBJECT}新增 $COUNT 个文件，"
    
    if [ -z "$BODY" ]; then
        BODY="[新增] ${FULL}"
    else
        BODY="${BODY}\n[新增] ${FULL}"
    fi
    HAS_CHANGE=1
fi

# 修订文件处理 (M)
MODIFIED_RAW=$(git diff --cached --name-status | awk '$1 ~ /^M/ {print $2}')
if [ -n "$MODIFIED_RAW" ]; then
    COUNT=$(echo "$MODIFIED_RAW" | wc -l | tr -d ' ')
    FULL=$(echo "$MODIFIED_RAW" | paste -sd ", " -)
    
    SUBJECT="${SUBJECT}修订 $COUNT 个文件，"
    
    if [ -z "$BODY" ]; then
        BODY="[修订] ${FULL}"
    else
        BODY="${BODY}\n[修订] ${FULL}"
    fi
    HAS_CHANGE=1
fi

# 删除文件处理 (D)
DELETED_RAW=$(git diff --cached --name-status | awk '$1 ~ /^D/ {print $2}')
if [ -n "$DELETED_RAW" ]; then
    COUNT=$(echo "$DELETED_RAW" | wc -l | tr -d ' ')
    FULL=$(echo "$DELETED_RAW" | paste -sd ", " -)
    
    SUBJECT="${SUBJECT}删除 $COUNT 个文件，"
    
    if [ -z "$BODY" ]; then
        BODY="[删除] ${FULL}"
    else
        BODY="${BODY}\n[删除] ${FULL}"
    fi
    HAS_CHANGE=1
fi

# 清理标题尾部逗号
SUBJECT=$(echo "$SUBJECT" | sed 's/，$//')

# 写入摘要：极简标题 + 空行 + 文件列表
if [ "$HAS_CHANGE" -eq 1 ]; then
    printf "%s\n\n%b\n" "$SUBJECT" "$BODY" > "$COMMIT_MSG_FILE"
fi