#!/bin/sh
# =============================================================================================
# 脚本名称：prepare-commit-msg
#
# 【功能】
# Git 提交预处理钩子。根据输入特征，自动将无效或简短的提交信息替换为具体的文件变更列表。
# 替换格式示例：“新增 a.txt; 修订 b.py; 删除 c.md”。
#
# 【触发与放行规则】
# 1. 触发替换：输入字符数 <= 阈值（默认10），或匹配 GitHub 默认提交格式。
# 2. 放行保留：输入字符数 > 阈值，且非 GitHub 默认格式（判定为有效自定义备注）。
#
# 【部署说明】（适用于仓库统一管理，免复制）
# 1. 存放路径：项目根目录 `.githooks/prepare-commit-msg`（必须无后缀名）。
# 2. 生效指令：在终端执行 `git config core.hooksPath .githooks`。
# 3. 权限要求：在终端执行 `chmod +x .githooks/prepare-commit-msg`。
# =============================================================================================

set -e

# 环境自适应
[ -d "/c/Portable Files" ] && export PATH="/c/Portable Files/PortableGit/bin:/c/Portable Files/PortableGit/usr/bin:$PATH"

COMMIT_MSG_FILE=$1
# 1. 获取并清洗消息
ORIGINAL_MSG=$(cat "$COMMIT_MSG_FILE" | xargs)
CLEAN_MSG=$(echo "$ORIGINAL_MSG" | sed 's/\[skip ci\]//g' | xargs)
CLEAN_LENGTH=$(echo -n "$CLEAN_MSG" | wc -m | tr -d ' ')

# 2. 判断是否需要接管 (长度不足 10 或 命中关键字)
if [ "$CLEAN_LENGTH" -lt 10 ] || [[ "$CLEAN_MSG" =~ ^(up|update|Update|Create|Delete|Rename) ]]; then
    
    # 3. 统计变更
    SUBJECT=""
    BODY=""
    HAS_CHANGE=0
    
    # 提取变更行并处理
    DIFF_DATA=$(git diff --cached --name-status)
    [ -z "$DIFF_DATA" ] && exit 0

    ADD_CNT=$(echo "$DIFF_DATA" | grep -c "^A" || true)
    MOD_CNT=$(echo "$DIFF_DATA" | grep -c "^M" || true)
    DEL_CNT=$(echo "$DIFF_DATA" | grep -c "^D" || true)

    [ "$ADD_CNT" -gt 0 ] && SUBJECT="${SUBJECT}新增 $ADD_CNT 个文件，" && BODY="${BODY}[新增] $(echo "$DIFF_DATA" | awk '$1=="A"{print $2}' | paste -sd ", " -)\n" && HAS_CHANGE=1
    [ "$MOD_CNT" -gt 0 ] && SUBJECT="${SUBJECT}修订 $MOD_CNT 个文件，" && BODY="${BODY}[修订] $(echo "$DIFF_DATA" | awk '$1=="M"{print $2}' | paste -sd ", " -)\n" && HAS_CHANGE=1
    [ "$DEL_CNT" -gt 0 ] && SUBJECT="${SUBJECT}删除 $DEL_CNT 个文件，" && BODY="${BODY}[删除] $(echo "$DIFF_DATA" | awk '$1=="D"{print $2}' | paste -sd ", " -)\n" && HAS_CHANGE=1

    if [ "$HAS_CHANGE" -eq 1 ]; then
        SUBJECT=$(echo "$SUBJECT" | sed 's/，$//')
        # 4. 自动识别核心语言 (可选，如不需要可删掉这部分)
        # 通过文件后缀粗略判断排名第一的语言
        TOP_LANG=$(echo "$DIFF_DATA" | awk -F. '{print $NF}' | sort | uniq -c | sort -nr | head -1 | awk '{print $2}' | tr '[:lower:]' '[:upper:]' | sed 's/YML/YAML/; s/JS/JavaScript/; s/PY/Python/')
        
        # 5. 组装最终消息 (保留原有的 [skip ci])
        SKIP_TAG=$(echo "$ORIGINAL_MSG" | grep -o "\[skip ci\]" || true)
        printf "%s (主语言: %s)\n\n%b\n%s" "$SUBJECT" "${TOP_LANG:-Unknown}" "$BODY" "$SKIP_TAG" > "$COMMIT_MSG_FILE"
    fi
fi